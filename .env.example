# =============================================================
# ImoOS — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.imos.cv

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgres://imos:imos_password@localhost:5432/imos
# For multi-tenant, the main DB is used — django-tenants creates schemas dynamically

# Redis (Cache + Celery Broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object Storage (S3-compatible — DigitalOcean Spaces or AWS S3)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=imos-media
AWS_S3_ENDPOINT_URL=https://fra1.digitaloceanspaces.com
AWS_S3_REGION_NAME=fra1
AWS_S3_CUSTOM_DOMAIN=media.imos.cv
MEDIA_URL=https://media.imos.cv/

# JWT Authentication
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (SMTP)
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@imos.cv
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=ImoOS <noreply@imos.cv>

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# imo.cv Integration
IMO_CV_API_URL=https://api.imo.cv/v1
IMO_CV_API_KEY=your-imo-cv-api-key
IMO_CV_WEBHOOK_SECRET=your-webhook-secret

# Sentry Error Tracking
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ENVIRONMENT=development

# Tenant Configuration
TENANT_BASE_DOMAIN=imos.cv
PUBLIC_SCHEMA_URLCONF=config.urls_public

# Currency
DEFAULT_CURRENCY=CVE
EUR_TO_CVE_RATE=110.265

# Compliance
DATA_RETENTION_OPERATIONAL_YEARS=2
DATA_RETENTION_FINANCIAL_YEARS=7
